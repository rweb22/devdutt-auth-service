# Devdutt Auth Service Environment Variables

# Application
NODE_ENV=development
PORT=3001
APP_NAME=devdutt-auth-service

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=devdutt
DB_PASSWORD=your_password_here
DB_NAME=devdutt_auth

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800
JWT_ISSUER=devdutt-auth-service

# RSA Keys (generate with: openssl genrsa -out keys/private.pem 2048)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Verification
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRES_IN=600

# CORS
CORS_ORIGIN=http://localhost:3000
